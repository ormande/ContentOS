{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["server.mjs", "src/**/*.js", "api/**/*.js", "scripts/**/*.mjs", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
